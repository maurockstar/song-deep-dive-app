<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>geeek — for the music you can't live without</title>
<script src="./gate.js?v=1.0"></script>
<script src="./support.js"></script>
</head>
<body>
<x-dc>
<helmet>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&amp;family=Space+Grotesk:wght@400;500;600;700&amp;family=Baloo+2:wght@500;600;700&amp;display=swap" rel="stylesheet">
<meta name="theme-color" content="#0E070C">
<style>
  html{scroll-behavior:smooth}
  html,body{margin:0;background:#0E070C;}
  *{box-sizing:border-box}
  a{color:inherit}
  .gk-feat.rev .gk-copy{order:2}
  .gk-feat.rev .gk-phonewrap{order:1}
  @media (max-width:820px){
    .gk-hero{grid-template-columns:1fr !important;gap:30px !important;padding:40px 20px 24px !important;text-align:center;}
    .gk-hero h1{font-size:clamp(36px,9vw,52px) !important;line-height:1.02 !important;}
    .gk-hero p{margin-left:auto !important;margin-right:auto !important;}
    .gk-bio{text-align:left;}
    .gk-chips{justify-content:center !important;}
    .gk-2col{grid-template-columns:1fr !important;gap:28px !important;}
    .gk-feat{padding:34px 0 !important;}
    .gk-feat .gk-copy{order:0 !important;}
    .gk-feat .gk-phonewrap{order:1 !important;}
    .gk-trio{grid-template-columns:1fr !important;gap:34px !important;}
    .gk-phonewrap{width:min(80vw,330px) !important;max-width:330px;margin-left:auto;margin-right:auto;}
    .gk-phonewrap .sc-host{width:100% !important;}
    h2{font-size:clamp(28px,7.5vw,42px) !important;}
    .gk-byom{flex-direction:column;align-items:flex-start !important;}
  }
  @keyframes gkb1{from{height:30%}to{height:100%}}
  @keyframes gkb2{from{height:92%}to{height:36%}}
  @keyframes gkb3{from{height:48%}to{height:88%}}
  @keyframes gkfloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}
  @keyframes gkglow{0%,100%{opacity:.45}50%{opacity:.8}}
  @keyframes gkmarq{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
</style>
</helmet>
<div style="background:radial-gradient(1100px 600px at 82% -8%,rgba(255,138,77,.13),transparent 60%),radial-gradient(900px 520px at 0% 12%,rgba(255,90,60,.07),transparent 55%),#0E070C;color:#E7DACE;font-family:'Space Grotesk',system-ui,sans-serif;min-height:100vh;overflow-x:hidden;">

  <!-- nav -->
  <nav style="position:sticky;top:0;z-index:20;display:flex;align-items:center;justify-content:space-between;padding:16px 28px;background:rgba(14,7,12,.72);backdrop-filter:blur(10px);border-bottom:1px solid #1E121A;">
    <div style="display:flex;align-items:center;font-family:'Space Grotesk';font-weight:700;font-size:24px;letter-spacing:-.03em;color:#F6ECE0;">g<span style="display:inline-flex;align-items:flex-end;gap:2px;height:17px;margin:0 3px;vertical-align:baseline;"><i style="width:5px;border-radius:3px;background:linear-gradient(180deg,#FFC64B,#FF8A4D);animation:gkb1 .9s ease-in-out infinite alternate;"></i><i style="width:5px;border-radius:3px;background:linear-gradient(180deg,#FFC64B,#FF8A4D);animation:gkb2 .78s ease-in-out infinite alternate;"></i><i style="width:5px;border-radius:3px;background:linear-gradient(180deg,#FFC64B,#FF8A4D);animation:gkb3 1.05s ease-in-out infinite alternate;"></i></span>k</div>
    <div style="display:flex;align-items:center;gap:26px;">
      <a href="#features" style="text-decoration:none;color:#BCA99B;font-size:14px;font-weight:500;">Features</a>
      <a href="#access" style="text-decoration:none;color:#BCA99B;font-size:14px;font-weight:500;">Get the beta</a>
      <a href="#access" style="text-decoration:none;background:linear-gradient(180deg,#FFB14D,#FF8A4D);color:#1A0B05;font-weight:700;font-size:14px;padding:9px 18px;border-radius:999px;box-shadow:0 0 22px -8px rgba(255,138,77,.6);">Get early access</a>
    </div>
  </nav>

  <!-- hero -->
  <header class="gk-hero" style="max-width:1180px;margin:0 auto;padding:68px 28px 44px;display:grid;grid-template-columns:1fr 330px;gap:52px;align-items:center;">
    <div>
      <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:#FF9F4D;margin-bottom:20px;">For the curious music lover</div>
      <h1 style="font-family:'Sora',sans-serif;font-weight:800;font-size:64px;line-height:1.0;letter-spacing:-.03em;color:#F6ECE0;margin:0 0 22px;">Every song is a<br>rabbit hole.</h1>
      <p style="font-size:19px;line-height:1.6;color:#BCA99B;margin:0 0 26px;max-width:46ch;">Play any song and geeek unfolds the whole story behind it — the people, the samples, the connections — in real time on Spotify or Apple Music. The more you know, the more you love it: dig in, play trivia with friends, take the mic, build a playlist and then go live your day.</p>
      <div class="gk-bio" style="display:inline-flex;flex-direction:column;gap:4px;border-left:3px solid #FF8A4D;padding:6px 0 6px 16px;">
        <div style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:20px;color:#F6ECE0;">No pre-made playlists. No algorithms deciding for you.</div>
        <div style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:20px;color:#FF9F4D;">You just do you.</div>
      </div>
    </div>
    <div style="position:relative;display:flex;justify-content:center;">
      <div style="position:absolute;width:330px;height:330px;border-radius:50%;background:radial-gradient(circle,rgba(255,138,77,.22),transparent 70%);filter:blur(10px);animation:gkglow 5s ease-in-out infinite;top:50%;left:50%;transform:translate(-50%,-50%);"></div>
      <div class="gk-phonewrap" style="position:relative;width:300px;">
        <dc-import name="AppPhone" cycle="true" style="width:300px;display:block;" hint-size="300px,640px"></dc-import>
      </div>
    </div>
  </header>


  <!-- features: each = the app, a different tab active -->
  <section id="features" style="max-width:1160px;margin:0 auto;padding:30px 28px 20px;">
    <div style="text-align:center;margin-bottom:8px;">
      <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#FF9F4D;margin-bottom:10px;">What you can do</div>
      <h2 style="font-family:'Sora',sans-serif;font-weight:800;font-size:44px;letter-spacing:-.02em;color:#F6ECE0;margin:0;">One song. A whole world behind it.</h2>
    </div>

    <div class="gk-2col gk-feat rev" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;padding:60px 0;">
      <div class="gk-copy">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#FF9F4D;margin-bottom:12px;">Deep dive</div>
        <h3 style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:34px;line-height:1.08;color:#F6ECE0;margin:0 0 12px;">Everything behind the song.</h3>
        <p style="font-size:17px;line-height:1.6;color:#BCA99B;margin:0 0 16px;max-width:42ch;">One glanceable fun fact to start &mdash; then tap <b style="color:#E7DACE;">Dive deeper</b> and go as far down the rabbit hole as you want. The story, the people, the samples and the connections, in real time on whatever you&rsquo;re playing.</p>
        <div style="display:inline-flex;align-items:center;gap:8px;color:#FF9F4D;font-weight:700;font-size:14px;">High-level by default, bottomless on demand</div>
      </div>
      <div class="gk-phonewrap" style="display:flex;justify-content:center;"><dc-import name="AppPhone" tab="cards" style="width:288px;display:block;" hint-size="288px,620px"></dc-import></div>
    </div>

    <div class="gk-2col gk-feat" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;padding:60px 0;border-top:1px solid #1E121A;">
      <div class="gk-copy">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#FF9F4D;margin-bottom:12px;">Trivia &amp; contests</div>
        <h3 style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:34px;line-height:1.08;color:#F6ECE0;margin:0 0 12px;">Prove you&rsquo;re the biggest fan.</h3>
        <p style="font-size:17px;line-height:1.6;color:#BCA99B;margin:0 0 16px;max-width:42ch;">Play solo against the clock, spin up a live room and challenge your friends, or go head-to-head with an artist&rsquo;s superfans worldwide for the global #1 spot.</p>
        <div style="display:inline-flex;align-items:center;gap:8px;color:#FF9F4D;font-weight:700;font-size:14px;">Solo &middot; Friends &middot; Worldwide contests</div>
      </div>
      <div class="gk-phonewrap" style="display:flex;justify-content:center;"><dc-import name="TriviaFriends" style="width:288px;display:block;" hint-size="288px,620px"></dc-import></div>
    </div>

    <div class="gk-2col gk-feat rev" style="display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;padding:60px 0;border-top:1px solid #1E121A;">
      <div class="gk-copy">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#FF9F4D;margin-bottom:12px;">Karaoke</div>
        <h3 style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:34px;line-height:1.08;color:#F6ECE0;margin:0 0 12px;">Drop the vocals, take the mic.</h3>
        <p style="font-size:17px;line-height:1.6;color:#BCA99B;margin:0 0 16px;max-width:42ch;">Flip <b style="color:#E7DACE;">Go vocal-less</b> and AI lifts the lead vocal in a tap, with time-synced lyrics that scroll and light up line by line as the song plays.</p>
        <div style="display:inline-flex;align-items:center;gap:8px;color:#FF9F4D;font-weight:700;font-size:14px;">Real-time lyrics, front and center</div>
      </div>
      <div class="gk-phonewrap" style="display:flex;justify-content:center;"><dc-import name="AppPhone" tab="karaoke" karaoke="true" style="width:288px;display:block;" hint-size="288px,620px"></dc-import></div>
    </div>
  </section>

  <!-- bring your own music -->
  <section style="max-width:1160px;margin:0 auto;padding:48px 28px 72px;">
    <div class="gk-byom" style="background:radial-gradient(700px 300px at 20% 0%,rgba(255,138,77,.12),transparent 60%),linear-gradient(180deg,#1E121A,#150C12);border:1px solid #2E1C28;border-radius:24px;padding:46px 44px;display:flex;align-items:center;justify-content:space-between;gap:40px;flex-wrap:wrap;">
      <div style="max-width:52ch;">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#FF9F4D;margin-bottom:12px;">Your music, your way</div>
        <h2 style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:34px;line-height:1.1;color:#F6ECE0;margin:0 0 10px;">Connect what you already use.</h2>
        <p style="font-size:17px;line-height:1.6;color:#BCA99B;margin:0;">Apple Music or Spotify &mdash; link a service and geeek follows along with whatever you&rsquo;re playing. We never put you in a locked room.</p>
      </div>
      <div style="display:flex;gap:20px;">
        <span style="display:inline-flex;flex-direction:column;align-items:center;gap:11px;"><span style="width:67px;height:67px;border-radius:16px;background:#241620;border:1px solid #3a2530;display:flex;align-items:center;justify-content:center;"><svg viewBox="0 0 24 24" width="34" height="34" fill="#B9ADA2"><path d="M17.05 12.04c-.03-2.4 1.96-3.55 2.05-3.61-1.12-1.64-2.86-1.86-3.48-1.89-1.48-.15-2.89.87-3.64.87-.75 0-1.91-.85-3.14-.83-1.62.02-3.11.94-3.94 2.39-1.68 2.91-.43 7.22 1.21 9.58.8 1.16 1.76 2.46 3.01 2.41 1.21-.05 1.67-.78 3.13-.78 1.46 0 1.87.78 3.14.76 1.3-.02 2.12-1.18 2.91-2.35.92-1.35 1.3-2.66 1.32-2.73-.03-.01-2.53-.97-2.56-3.84z"></path><path d="M14.86 5.36c.66-.8 1.11-1.92.99-3.03-.95.04-2.11.63-2.79 1.43-.61.71-1.14 1.85-1 2.94 1.06.08 2.14-.54 2.8-1.34z"></path></svg></span><span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.08em;color:#8A7668;">APPLE MUSIC</span></span>
        <span style="display:inline-flex;flex-direction:column;align-items:center;gap:11px;"><span style="width:67px;height:67px;border-radius:50%;background:#241620;border:1px solid #3a2530;display:flex;align-items:center;justify-content:center;"><svg viewBox="0 0 24 24" width="41" height="41"><circle cx="12" cy="12" r="11" fill="#B9ADA2"></circle><g fill="none" stroke="#241620" stroke-width="1.9" stroke-linecap="round"><path d="M5.6 9c4.6-1.3 9.6-.9 13.2 1.4"></path><path d="M6.5 12.6c3.7-1.1 7.7-.7 10.7 1.2"></path><path d="M7.3 15.9c2.7-.8 5.7-.4 8.1 1"></path></g></svg></span><span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.08em;color:#8A7668;">SPOTIFY</span></span>
      </div>
    </div>
  </section>

  <!-- beta access -->
  <section id="demo" style="max-width:1000px;margin:0 auto;padding:20px 28px 90px;text-align:center;">
    <div id="access">
      <h3 style="font-family:'Baloo 2',sans-serif;font-weight:600;font-size:30px;color:#F6ECE0;margin:0 0 8px;">Be first into the beta.</h3>
      <p style="color:#BCA99B;font-size:16px;margin:0 0 22px;">We grow on purpose &mdash; family and friends first, then a widening circle of music geeks. Leave your email to join the line.</p>
      <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;max-width:460px;margin:0 auto;">
        <input type="email" placeholder="you@email.com" style="flex:1;min-width:220px;background:#F5EFE6;border:1px solid #D8C6B2;border-radius:999px;color:#1E1B17;padding:14px 20px;font-size:15px;font-family:inherit;">
        <button style="border:none;background:linear-gradient(180deg,#FFB14D,#FF8A4D);color:#1A0B05;font-weight:700;font-size:15px;padding:14px 24px;border-radius:999px;cursor:pointer;font-family:inherit;">Get early access</button>
      </div>
    </div>
  </section>

  <!-- footer -->
  <footer style="border-top:1px solid #1E121A;padding:32px 28px;max-width:1160px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;font-family:'Space Grotesk';font-weight:700;font-size:20px;letter-spacing:-.03em;color:#F6ECE0;">g<span style="display:inline-flex;align-items:flex-end;gap:2px;height:14px;margin:0 3px;"><i style="width:4px;height:7px;border-radius:2px;background:linear-gradient(180deg,#FFC64B,#FF8A4D);"></i><i style="width:4px;height:14px;border-radius:2px;background:linear-gradient(180deg,#FFC64B,#FF8A4D);"></i><i style="width:4px;height:10px;border-radius:2px;background:linear-gradient(180deg,#FFC64B,#FF8A4D);"></i></span>k</div>
    <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:11px;letter-spacing:.08em;color:#5E4E44;text-transform:uppercase;">For people who geek out about music — then go live.</div>
    <div style="display:flex;gap:18px;font-size:13px;color:#8A7668;"><a href="#faqs" style="color:#8A7668;text-decoration:none;">FAQs</a><a href="#about" style="color:#8A7668;text-decoration:none;">About</a><a href="#" style="color:#8A7668;text-decoration:none;">Privacy</a><a href="#" style="color:#8A7668;text-decoration:none;">Contact</a></div>
  </footer>

</div>
